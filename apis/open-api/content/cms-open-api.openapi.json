{
  "openapi": "3.1.2",
  "info": {
    "title": "SDKWork CMS Open API",
    "version": "1.0.0",
    "x-sdkwork-owner": "sdkwork-cms",
    "x-sdkwork-api-authority": "sdkwork-cms.open"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:18080"
    }
  ],
  "tags": [
    {
      "name": "cms",
      "description": "CMS public integration delivery API.",
      "x-sdk-nested-resource-surface": true
    }
  ],
  "paths": {
    "/cms/v3/api/entries": {
      "get": {
        "tags": ["cms"],
        "summary": "List published CMS entries",
        "operationId": "cms.entries.list",
        "parameters": [
          { "$ref": "#/components/parameters/SiteCode" },
          { "$ref": "#/components/parameters/ChannelCode" },
          { "$ref": "#/components/parameters/Locale" },
          { "$ref": "#/components/parameters/ContentTypeCode" },
          { "$ref": "#/components/parameters/TermCode" },
          { "$ref": "#/components/parameters/Cursor" },
          { "$ref": "#/components/parameters/Limit" }
        ],
        "responses": { "200": { "$ref": "#/components/responses/CmsEntryPageOk" }, "400": { "$ref": "#/components/responses/Problem" }, "401": { "$ref": "#/components/responses/Problem" } },
        "security": [{ "ApiKey": [] }],
        "x-sdkwork-owner": "sdkwork-cms",
        "x-sdkwork-api-authority": "sdkwork-cms.open",
        "x-sdkwork-domain": "content",
        "x-sdkwork-resource": "cms.entries",
        "x-sdkwork-auth-mode": "api-key",
        "x-sdkwork-public": false
      }
    },
    "/cms/v3/api/entries/{entryId}": {
      "get": {
        "tags": ["cms"],
        "summary": "Retrieve a published CMS entry",
        "operationId": "cms.entries.retrieve",
        "parameters": [
          { "name": "entryId", "in": "path", "required": true, "schema": { "type": "string", "format": "int64", "x-sdkwork-int64-string": true } }
        ],
        "responses": { "200": { "$ref": "#/components/responses/CmsEntryOk" }, "400": { "$ref": "#/components/responses/Problem" }, "401": { "$ref": "#/components/responses/Problem" }, "404": { "$ref": "#/components/responses/Problem" } },
        "security": [{ "ApiKey": [] }],
        "x-sdkwork-owner": "sdkwork-cms",
        "x-sdkwork-api-authority": "sdkwork-cms.open",
        "x-sdkwork-domain": "content",
        "x-sdkwork-resource": "cms.entries",
        "x-sdkwork-auth-mode": "api-key",
        "x-sdkwork-public": false
      }
    },
    "/cms/v3/api/entries:resolve": {
      "get": {
        "tags": ["cms"],
        "summary": "Resolve a published CMS entry by slug",
        "operationId": "cms.entries.resolve",
        "parameters": [
          { "$ref": "#/components/parameters/SiteCode" },
          { "$ref": "#/components/parameters/ChannelCode" },
          { "$ref": "#/components/parameters/Locale" },
          { "name": "slug", "in": "query", "required": true, "schema": { "type": "string", "maxLength": 512 } }
        ],
        "responses": { "200": { "$ref": "#/components/responses/CmsEntryOk" }, "400": { "$ref": "#/components/responses/Problem" }, "401": { "$ref": "#/components/responses/Problem" }, "404": { "$ref": "#/components/responses/Problem" } },
        "security": [{ "ApiKey": [] }],
        "x-sdkwork-owner": "sdkwork-cms",
        "x-sdkwork-api-authority": "sdkwork-cms.open",
        "x-sdkwork-domain": "content",
        "x-sdkwork-resource": "cms.entries",
        "x-sdkwork-auth-mode": "api-key",
        "x-sdkwork-public": false
      }
    },
    "/cms/v3/api/pages:resolve": {
      "get": {
        "tags": ["cms"],
        "summary": "Resolve a published CMS page by path",
        "operationId": "cms.pages.resolve",
        "parameters": [
          { "$ref": "#/components/parameters/SiteCode" },
          { "$ref": "#/components/parameters/ChannelCode" },
          { "$ref": "#/components/parameters/Locale" },
          { "name": "path", "in": "query", "required": true, "schema": { "type": "string", "maxLength": 1024 } }
        ],
        "responses": { "200": { "$ref": "#/components/responses/CmsPageOk" }, "400": { "$ref": "#/components/responses/Problem" }, "401": { "$ref": "#/components/responses/Problem" }, "404": { "$ref": "#/components/responses/Problem" } },
        "security": [{ "ApiKey": [] }],
        "x-sdkwork-owner": "sdkwork-cms",
        "x-sdkwork-api-authority": "sdkwork-cms.open",
        "x-sdkwork-domain": "content",
        "x-sdkwork-resource": "cms.pages",
        "x-sdkwork-auth-mode": "api-key",
        "x-sdkwork-public": false
      }
    },
    "/cms/v3/api/feeds/{feedCode}/items": {
      "get": {
        "tags": ["cms"],
        "summary": "List published CMS feed items",
        "operationId": "cms.feeds.items.list",
        "parameters": [
          { "name": "feedCode", "in": "path", "required": true, "schema": { "type": "string", "maxLength": 128 } },
          { "$ref": "#/components/parameters/SiteCode" },
          { "$ref": "#/components/parameters/ChannelCode" },
          { "$ref": "#/components/parameters/Locale" },
          { "$ref": "#/components/parameters/Cursor" },
          { "$ref": "#/components/parameters/Limit" }
        ],
        "responses": { "200": { "$ref": "#/components/responses/CmsFeedItemPageOk" }, "400": { "$ref": "#/components/responses/Problem" }, "401": { "$ref": "#/components/responses/Problem" }, "404": { "$ref": "#/components/responses/Problem" } },
        "security": [{ "ApiKey": [] }],
        "x-sdkwork-owner": "sdkwork-cms",
        "x-sdkwork-api-authority": "sdkwork-cms.open",
        "x-sdkwork-domain": "content",
        "x-sdkwork-resource": "cms.feeds.items",
        "x-sdkwork-auth-mode": "api-key",
        "x-sdkwork-public": false
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "parameters": {
      "SiteCode": { "name": "siteCode", "in": "query", "required": true, "schema": { "type": "string", "maxLength": 128 } },
      "ChannelCode": { "name": "channelCode", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 128 } },
      "Locale": { "name": "locale", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 32, "default": "en-US" } },
      "ContentTypeCode": { "name": "contentTypeCode", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 128 } },
      "TermCode": { "name": "termCode", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 128 } },
      "Cursor": { "name": "cursor", "in": "query", "required": false, "schema": { "type": "string", "maxLength": 512 } },
      "Limit": { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "format": "int32", "minimum": 1, "maximum": 100, "default": 20 } }
    },
    "responses": {
      "CmsEntryOk": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CmsEntry" } } } },
      "CmsEntryPageOk": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CmsEntryPage" } } } },
      "CmsPageOk": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CmsPage" } } } },
      "CmsFeedItemPageOk": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CmsFeedItemPage" } } } },
      "Problem": { "description": "Problem detail", "content": { "application/problem+json": { "schema": { "$ref": "#/components/schemas/ProblemDetail" } } } }
    },
    "schemas": {
      "CmsEntry": {
        "type": "object",
        "required": ["id", "uuid", "siteId", "contentTypeCode", "title", "slug", "locale", "publicationStatus"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "int64", "x-sdkwork-int64-string": true },
          "uuid": { "type": "string" },
          "siteId": { "type": "string", "format": "int64", "x-sdkwork-int64-string": true },
          "contentTypeCode": { "type": "string" },
          "channelCode": { "type": "string" },
          "title": { "type": "string" },
          "slug": { "type": "string" },
          "summary": { "type": "string" },
          "locale": { "type": "string" },
          "bodyFormat": { "type": "string" },
          "bodyText": { "type": "string" },
          "bodyHtml": { "type": "string" },
          "blocks": { "type": "object", "additionalProperties": true },
          "fields": { "type": "object", "additionalProperties": true },
          "media": { "type": "array", "items": { "$ref": "#/components/schemas/CmsMediaRef" } },
          "terms": { "type": "array", "items": { "$ref": "#/components/schemas/CmsTermRef" } },
          "seo": { "type": "object", "additionalProperties": true },
          "publicationStatus": { "type": "string", "enum": ["unpublished", "scheduled", "published", "unpublished_after_publish", "rolled_back"] },
          "publishedAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CmsPage": {
        "type": "object",
        "required": ["id", "siteId", "path", "title", "locale", "blocks"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "int64", "x-sdkwork-int64-string": true },
          "siteId": { "type": "string", "format": "int64", "x-sdkwork-int64-string": true },
          "channelCode": { "type": "string" },
          "locale": { "type": "string" },
          "path": { "type": "string" },
          "title": { "type": "string" },
          "seo": { "type": "object", "additionalProperties": true },
          "blocks": { "type": "array", "items": { "$ref": "#/components/schemas/CmsPageBlock" } },
          "publishedAt": { "type": "string", "format": "date-time" }
        }
      },
      "CmsPageBlock": {
        "type": "object",
        "required": ["id", "slotCode", "blockKind", "sortOrder", "config"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "int64", "x-sdkwork-int64-string": true },
          "slotCode": { "type": "string" },
          "blockCode": { "type": "string" },
          "blockKind": { "type": "string" },
          "refType": { "type": "string" },
          "refId": { "type": "string", "format": "int64", "x-sdkwork-int64-string": true },
          "config": { "type": "object", "additionalProperties": true },
          "sortOrder": { "type": "integer", "format": "int32" }
        }
      },
      "CmsFeedItem": {
        "type": "object",
        "required": ["id", "itemKind", "sortOrder"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "format": "int64", "x-sdkwork-int64-string": true },
          "itemKind": { "type": "string" },
          "entry": { "$ref": "#/components/schemas/CmsEntry" },
          "page": { "$ref": "#/components/schemas/CmsPage" },
          "externalUrl": { "type": "string" },
          "operatorTitle": { "type": "string" },
          "operatorSummary": { "type": "string" },
          "operatorMedia": { "type": "object", "additionalProperties": true },
          "pinned": { "type": "boolean" },
          "sortOrder": { "type": "integer", "format": "int32" }
        }
      },
      "CmsEntryPage": {
        "type": "object",
        "required": ["items"],
        "additionalProperties": false,
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CmsEntry" } },
          "nextCursor": { "type": "string" }
        }
      },
      "CmsFeedItemPage": {
        "type": "object",
        "required": ["items"],
        "additionalProperties": false,
        "properties": {
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CmsFeedItem" } },
          "nextCursor": { "type": "string" },
          "snapshotId": { "type": "string", "format": "int64", "x-sdkwork-int64-string": true }
        }
      },
      "CmsMediaRef": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "role": { "type": "string" },
          "driveUri": { "type": "string" },
          "mediaResourceId": { "type": "string" },
          "altText": { "type": "string" },
          "caption": { "type": "string" },
          "snapshot": { "type": "object", "additionalProperties": true }
        }
      },
      "CmsTermRef": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "taxonomyCode": { "type": "string" },
          "termCode": { "type": "string" },
          "slug": { "type": "string" },
          "name": { "type": "string" }
        }
      },
      "ProblemDetail": {
        "type": "object",
        "required": ["type", "title", "status"],
        "additionalProperties": true,
        "properties": {
          "type": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "integer", "format": "int32" },
          "detail": { "type": "string" },
          "instance": { "type": "string" },
          "requestId": { "type": "string" },
          "code": { "type": "string" }
        }
      }
    }
  }
}

