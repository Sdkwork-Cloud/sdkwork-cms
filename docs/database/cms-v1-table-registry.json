{
  "schemaVersion": 1,
  "kind": "sdkwork.database.table-registry",
  "domain": "content",
  "capability": "cms",
  "modulePrefix": "cms",
  "owner": "sdkwork-cms",
  "migration": "crates/sdkwork-content-cms-repository-sqlx/migrations/0001_cms_v1_foundation.sql",
  "dependencyTables": {
    "reuseByReferenceOnly": [
      {
        "workspace": "../sdkwork-appbase",
        "tables": ["iam_tenant", "iam_user", "iam_organization", "iam_role", "iam_permission", "iam_policy", "iam_audit_event", "iam_security_event"],
        "cmsColumns": ["tenant_id", "organization_id", "created_by", "updated_by", "author_user_id", "owner_user_id", "actor_user_id"],
        "rule": "CMS stores IAM IDs and consumes IAM SDK/service contracts; CMS must not duplicate IAM fact tables."
      },
      {
        "workspace": "../sdkwork-drive",
        "tables": ["dr_drive_space", "dr_drive_node", "dr_drive_storage_object", "dr_drive_upload_session", "dr_drive_node_version"],
        "cmsColumns": ["drive_space_id", "drive_node_id", "drive_uri", "media_resource_id", "media_snapshot_json"],
        "rule": "CMS stores Drive/MediaResource references and snapshots only; file lifecycle stays in Drive."
      },
      {
        "workspace": "../sdkwork-search",
        "tables": ["search_index", "search_document", "search_ranking_profile", "search_recommendation_strategy", "search_query_suggestion", "search_embedding_job"],
        "cmsColumns": ["ranking_profile_ref"],
        "rule": "CMS emits search sync/ranking requests through outbox and SDK ports; search projections stay in Search."
      },
      {
        "workspace": "../sdkwork-comments",
        "tables": ["comments_*", "engagement_*"],
        "cmsColumns": [],
        "rule": "Public comments, likes, favorites, and engagement counters stay dependency-owned."
      },
      {
        "workspace": "../sdkwork-messaging",
        "tables": ["messaging_*"],
        "cmsColumns": [],
        "rule": "Workflow notifications are emitted through Messaging SDK or outbox events."
      }
    ]
  },
  "tables": [
