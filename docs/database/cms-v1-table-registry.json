      "purpose": "CMS site/workspace boundary for locale, domain, delivery, and publish settings.",
      "ownedFacts": true,
      "primaryQueries": ["backend site list", "site bootstrap", "site-scoped management"],
      "keyColumns": ["id", "uuid", "tenant_id", "organization_id", "code", "default_locale", "default_channel_id", "status", "version"],
      "jsonColumns": ["domain_config_json", "locale_config_json", "settings_json", "publish_config_json"],
      "indexes": ["uk_cms_site_tenant_code", "idx_cms_site_tenant_status"]
    },
    {
      "name": "cms_channel",
      "profile": "dictionary_entity",
